spring:
  datasource:
    url: jdbc:mysql://localhost:3306/dumbbell?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: root
    password:  # 실제 비밀번호로 변경하세요
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update          # 개발 중: update / 운영: validate
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect

jwt:
  secret:  # 반드시 변경하세요:  32자 이상
  expiration: 86400000   # 24시간 (ms)

server:
  port: 8080

google:
  gemini:
    api-key: # ai api키 입력하세요